{
  "info": {
    "_postman_id": "b7f447f2-28ca-4bfc-bcb0-45a93ce3cf5e",
    "name": "UberEats API",
    "description": "Collection complete REST + GraphQL + WebSocket demo for soutenance.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:3000" },
    { "key": "access_token", "value": "" },
    { "key": "refresh_token", "value": "" },
    { "key": "restaurant_id", "value": "" },
    { "key": "dish_id", "value": "" },
    { "key": "order_id", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"Password123!\"\n}"
            },
            "url": "{{base_url}}/auth/register"
          },
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('Status 201', function () { pm.response.to.have.status(201); });"] } }]
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"Password123!\"\n}"
            },
            "url": "{{base_url}}/auth/login"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
                  "const json = pm.response.json();",
                  "if (json.accessToken) pm.collectionVariables.set('access_token', json.accessToken);",
                  "if (json.refreshToken) pm.collectionVariables.set('refresh_token', json.refreshToken);"
                ]
              }
            }
          ]
        },
        {
          "name": "Refresh",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"refreshToken\": \"{{refresh_token}}\"\n}" },
            "url": "{{base_url}}/auth/refresh"
          }
        },
        {
          "name": "Me",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{base_url}}/auth/me"
          }
        }
      ]
    },
    {
      "name": "Restaurants",
      "item": [
        { "name": "List restaurants", "request": { "method": "GET", "url": "{{base_url}}/restaurants?limit=10&offset=0" } },
        {
          "name": "Create my restaurant",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"My Resto\",\n  \"city\": \"Lyon\",\n  \"address\": \"1 rue test\"\n}"
            },
            "url": "{{base_url}}/restaurants"
          }
        },
        { "name": "Get my restaurant", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }], "url": "{{base_url}}/restaurants/me" } }
      ]
    },
    {
      "name": "Dishes",
      "item": [
        {
          "name": "Create dish",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Burger\",\n  \"price\": 12.5,\n  \"description\": \"Burger maison\"\n}"
            },
            "url": "{{base_url}}/restaurants/{{restaurant_id}}/dishes"
          }
        },
        { "name": "List dishes by restaurant", "request": { "method": "GET", "url": "{{base_url}}/restaurants/{{restaurant_id}}/dishes?limit=10&offset=0" } },
        { "name": "Get dish by id", "request": { "method": "GET", "url": "{{base_url}}/dishes/{{dish_id}}" } }
      ]
    },
    {
      "name": "Orders",
      "item": [
        {
          "name": "Create order",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"restaurantId\": \"{{restaurant_id}}\",\n  \"items\": [{ \"dishId\": \"{{dish_id}}\", \"quantity\": 2 }]\n}"
            },
            "url": "{{base_url}}/orders"
          }
        },
        { "name": "Get order", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }], "url": "{{base_url}}/orders/{{order_id}}" } },
        { "name": "Cancel order", "request": { "method": "DELETE", "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }], "url": "{{base_url}}/orders/{{order_id}}" } }
      ]
    },
    {
      "name": "Users",
      "item": [
        { "name": "Get my user profile", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }], "url": "{{base_url}}/users/me" } }
      ]
    },
    {
      "name": "Docs",
      "item": [
        { "name": "OpenAPI JSON", "request": { "method": "GET", "url": "{{base_url}}/documentation/json" } },
        { "name": "Swagger UI", "request": { "method": "GET", "url": "{{base_url}}/docs" } }
      ]
    },
    {
      "name": "GraphQL",
      "item": [
        {
          "name": "GraphQL query restaurants",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"query { restaurants(limit: 5, offset: 0) { data { id name city } pagination { total limit offset } } }\"\n}"
            },
            "url": "{{base_url}}/graphql"
          }
        },
        {
          "name": "GraphQL mutation create order",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"mutation($input: CreateOrderInput!) { createOrder(input: $input) { id status totalPrice } }\",\n  \"variables\": {\n    \"input\": {\n      \"restaurantId\": \"{{restaurant_id}}\",\n      \"items\": [{ \"dishId\": \"{{dish_id}}\", \"quantity\": 1 }]\n    }\n  }\n}"
            },
            "url": "{{base_url}}/graphql"
          }
        }
      ]
    },
    {
      "name": "WebSocket demo",
      "item": [
        {
          "name": "Restaurant notifications WS",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "ws://localhost:3000/ws/restaurants/me/orders"
          }
        }
      ]
    }
  ]
}
